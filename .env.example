# AI OS — environment variables
# Copy to .env and fill in values

# ── Brand ──────────────────────────────────────────────────────────────────────
BRAND=sc              # sc | hfm | default

# ── Ports ──────────────────────────────────────────────────────────────────────
API_PORT=8787
VITE_PORT=4321

# ── Data directory ─────────────────────────────────────────────────────────────
# AIOS_DATA_DIR=~/.ai-os

# ── AI Chat backend (choose one) ───────────────────────────────────────────────

# Option A: OpenRouter (recommended — cheap minimax-m3 for SC)
OPENROUTER_API_KEY=sk-or-v1-...
# MODEL=minimax/minimax-m3   # default; override per brand if needed

# Option B: Hermes agent bridge (if you have a Hermes instance running)
# HERMES_API_URL=http://localhost:3000
# HERMES_API_TOKEN=your-hermes-token

# ── Email (for automation send_email actions) ───────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourcompany.com
